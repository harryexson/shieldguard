# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:5000,http://localhost:8081

# API key protection for mutating endpoints. When REQUIRE_API_KEY=true all
# mutating routes require a matching x-api-key header. A default dev key is
# used when this is false. Always set a strong API_KEY in production.
REQUIRE_API_KEY=false
API_KEY=dev-shieldguard-key

# Stripe (optional — billing degrades gracefully without it)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_FAMILY=
