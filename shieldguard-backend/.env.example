# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:5000,http://localhost:8081

# API key protection. When REQUIRE_API_KEY=true, ALL vault / privacy / sync /
# command / audit / incident / backup routes require a matching API key sent
# ONLY via the `x-api-key` request HEADER (never a query string — query-string
# keys leak into logs and proxies). A default dev key is used when this is false.
# IMPORTANT: the mobile/office clients must send this header in production, OR
# the data-plane routes will return 401. Always set a strong, unique API_KEY in
# production and rotate it regularly.
REQUIRE_API_KEY=false
API_KEY=dev-shieldguard-key

# Stripe (optional — billing degrades gracefully without it)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_FAMILY=

# Transactional email (optional). When SMTP_HOST + EMAIL_FROM are unset, emails
# are written to .emails/ as .html files (dev fallback) instead of being sent.
EMAIL_FROM=alerts@shieldguard.app
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Where the confirmation email points users to install/use the app.
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.shieldguard
APP_STORE_URL=https://apps.apple.com/app/shieldguard/id000000000
DASHBOARD_URL=http://localhost:3001
